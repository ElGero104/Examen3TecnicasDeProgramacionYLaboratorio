{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar Temperatura",
            "type": "shell",
            "command": "javac",
            "args": [
                "-cp",
                "lib/*",
                "-d",
                "bin",
                "src/App.java",
                "src/FrmTemperaturas.java",
                "src/modelos/TemperaturaCiudad.java",
                "src/servicios/TemperaturaCiudadServicio.java",
                "src/controladores/TemperaturaCiudadControlador.java"
            ],
            "group": "build",
            "problemMatcher": "$javac"
        },
        {
            "label": "Ejecutar Temperatura",
            "type": "shell",
            "command": "java",
            "args": [
                "-cp",
                "bin;lib/*",
                "App"
            ],
            "dependsOn": "Compilar Temperatura"
        }
    ]
}
